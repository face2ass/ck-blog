<head>
  <meta charset="utf-8">
  <%
  var title = page.title;

  if (is_archive()) {
    title = '归档';

    if (is_month()) {
      title += ': ' + page.year + '/' + page.month;
    } else if (is_year()) {
      title += ': ' + page.year;
    }
  } else if (is_category()) {
    title = '分类' + ': ' + page.category;
  } else if (is_tag()) {
    title = '标签' + ': ' + page.tag;
  }
  %>
  <title>
    <% if (title){ %>
      <%= title %> |
    <% } %>
    <%= config.title %>
  </title>
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
  <meta name="algolia-site-verification"  content="8A22A986FCA516FD" />
  <% if (theme.favicon){ %>
    <%- favicon_tag(theme.favicon) %>
  <% } %>
  <script>
    var _hmt = _hmt || [];
    (function() {
      var hm = document.createElement("script");
      hm.src = "https://hm.baidu.com/hm.js?4e50d8fc76696aafc4ddc57e8dca36f7";
      var s = document.getElementsByTagName("script")[0];
      s.parentNode.insertBefore(hm, s);
    })();
  </script>
  <%- css('bootstrap/bootstrap@5.3.3.min.css') %>
  <%- css('style/instantsearch@8.12.0satellite-min.css') %>
  <%- css('style/index') %>

  <%# 放在head避免夜间模式屏幕在刷新时闪一下 %>
  <%- js('js/color-modes.js') %>

  <%- js('js/algoliasearch@5.50.0.browser.umd.js') %>
  <%- js('js/instantsearch@4.92.1.production.min.js') %>
</head>
